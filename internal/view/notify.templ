package view

// appendMessage wraps content in the OOB swap container that
// appends to the #messages element.
templ appendMessage() {
	<div id={ ElementMessages } hx-swap-oob="beforeend">
		{ children... }
	</div>
}

templ Notify(message string) {
	@appendMessage() {
		<div class="mx-auto text-center text-sm text-stone-500 dark:text-stone-400 py-2">
			{ message }
		</div>
	}
}
