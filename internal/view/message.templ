package view

templ Message(encrypted string, iv string, self bool) {
	<div
		if self {
			class="ml-auto max-w-[75%] rounded-lg bg-indigo-600 px-3 py-2 text-sm text-white"
		} else {
			class="mr-auto max-w-[75%] rounded-lg bg-gray-200 dark:bg-gray-700 px-3 py-2 text-sm"
		}
		data-encrypted={ encrypted }
		data-iv={ iv }
		hx-swap-oob="beforeend:#messages"
	>
		...
	</div>
}
